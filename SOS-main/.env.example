# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sosfyp?appName=Cluster0
MONGODB_DB=sosfyp

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000 | Production: your Vercel URL
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ─── Gemini AI (free tier — get key at https://aistudio.google.com/apikey) ────
# Used for: AI chatbot (/api/ai-chat) + audio distress detection (/api/audio-translate)
GEMINI_API_KEY=

# ─── Emotion Recognition API ──────────────────────────────────────────────────
# Local dev: http://localhost:8001
# Production: deploy emotion-api to Railway/Render and set URL here
NEXT_PUBLIC_EMOTION_API_URL=http://localhost:8001

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-chars
